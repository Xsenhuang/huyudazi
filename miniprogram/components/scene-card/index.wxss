.scene-card-wrapper {
  display: flex;
  margin-bottom: 40rpx;
  width: 100%;
}

.align-left {
  justify-content: flex-start;
  padding-left: 32rpx;
  padding-right: 120rpx;
}

.align-right {
  justify-content: flex-flex-end;
  padding-left: 120rpx;
  padding-right: 32rpx;
}

.scene-card {
  position: relative;
  display: flex;
  align-items: center;
  background: var(--color-card-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
  transition: transform 0.2s ease, opacity 0.3s ease;
}

.scene-card:active {
  transform: scale(0.98);
}

.status-locked {
  opacity: 0.6;
  filter: grayscale(80%);
}

.status-completed {
  border: 2rpx solid var(--color-completed);
  background-color: rgba(193, 140, 93, 0.05);
}

.icon-container {
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-placeholder {
  width: 96rpx;
  height: 96rpx;
  background: #F0EAD6;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-primary);
}

.status-completed .icon-placeholder {
  background: var(--color-completed);
  color: #fff;
}

.content-container {
  flex: 1;
  min-width: 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.badge-LOCKED {
  background: #f0f0f0;
  color: var(--color-text-light);
}

.badge-PLAYING {
  background: rgba(232, 176, 91, 0.15);
  color: var(--color-primary);
  border: 1rpx solid rgba(232, 176, 91, 0.3);
}

.badge-COMPLETED {
  background: rgba(193, 140, 93, 0.1);
  color: var(--color-completed);
}

.sub-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.stamp-overlay {
  position: absolute;
  top: 50%;
  right: 24rpx;
  transform: translateY(-50%) rotate(-15deg);
  opacity: 0.8;
  pointer-events: none;
}

.stamp-circle {
  width: 100rpx;
  height: 100rpx;
  border: 4rpx solid var(--color-completed);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-completed);
  font-size: 24rpx;
  font-weight: bold;
  background: rgba(255, 255, 255, 0.8);
}

.lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.lock-icon {
  font-size: 48rpx;
  opacity: 0.8;
}
