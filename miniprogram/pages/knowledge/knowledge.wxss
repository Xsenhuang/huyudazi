.page-scroll {
  height: 100vh;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  background: #F8F8F8;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 88rpx;
  padding-top: 20px;
  z-index: 100;
  pointer-events: none;
  background: transparent;
}

.custom-nav-logo {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 36px;
  height: 36px;
  top: 24px;
  border-radius: 10rpx;
}

.level-tabs {
  width: 100%;
  padding: calc(env(safe-area-inset-top) + 88rpx + 40rpx) 0 32rpx;
  box-sizing: border-box;
}

.level-tabs__inner {
  padding: 24rpx 40rpx 32rpx;
  display: inline-flex;
  align-items: center;
  white-space: nowrap;
  gap: 20rpx;
}

.level-tab {
  padding: 24rpx 48rpx;
  border-radius: 140rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #FFFFFF;
  color: #1B1B1B;
  box-shadow: 0 0 24rpx 0 rgba(0, 0, 0, 0.12);
}

.level-tab.is-active {
  background: linear-gradient(134deg, #F15D22 0%, #FAB570 93%);
  color: #FFFFFF;
  box-shadow: 0 0 24rpx 0 rgba(0, 0, 0, 0.16);
}

.level-tab__level {
  font-size: 46rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.level-tab__count {
  font-size: 26rpx;
  font-weight: 400;
}

.cards {
  flex: 1;
  width: 100%;
  padding-top: 80rpx;
  box-sizing: border-box;
}

.cards__swiper {
  width: 100%;
  height: 680rpx;
  margin-top: 60rpx;
}

.card-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
}

.knowledge-card {
  width: 432rpx;
  border-radius: 40rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 8rpx 4rpx 24rpx 0 rgba(0, 0, 0, 0.08);
  transform: scale(0.86);
  transition: transform 220ms ease, opacity 220ms ease;
  opacity: 0.85;
}

.knowledge-card.is-active {
  transform: scale(1);
  opacity: 1;
}

.knowledge-card__top {
  height: 482rpx;
  padding: 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.knowledge-card__en {
  font-size: 40rpx;
  font-weight: 500;
  color: #1B1B1B;
  word-break: break-word;
  line-height: 1.3;
}

.knowledge-card__zh {
  font-size: 48rpx;
  font-weight: 500;
  color: #1B1B1B;
  word-break: break-word;
  line-height: 1.3;
}

.knowledge-card__bottom {
  padding: 32rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.knowledge-card__desc {
  font-size: 34rpx;
  font-weight: 500;
  color: #1B1B1B;
}

.bottom-space {
  height: calc(env(safe-area-inset-bottom) + 180rpx);
}
