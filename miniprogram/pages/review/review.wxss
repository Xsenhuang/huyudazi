/* 页面整体 */
.page {
  min-height: 100vh;
  background: #F8F8F8;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  pointer-events: none;
  background: transparent;
}

.custom-nav-logo {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  width: 36px;
  height: 36px;
  border-radius: 10rpx;
}

/* 仪表盘视图 */
.dash {
  padding: 0 20rpx 180rpx;
  box-sizing: border-box;
}

/* ==================== 我的生词记录卡片 ==================== */
.vocab-card {
  margin-top: 20rpx;
  border-radius: 16px;
  padding: 20px;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.vocab-card-title {
  font-size: 20px;
  font-weight: 600;
  color: #1B1B1B;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.vocab-grid {
  display: flex;
  flex-direction: row;
  gap: 16px;
  flex-wrap: wrap;
}

.vocab-grid-row {
  display: flex;
  flex-direction: row;
  gap: 16px;
  width: 100%;
}

.vocab-item {
  flex: 1;
  border-radius: 20px;
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  min-height: 80px;
  justify-content: center;
}

/* 词汇 - 蓝色渐变 */
.vocab-item-vocab {
  background: linear-gradient(180deg, #A3DCFF 0%, #FFFFFF 100%);
}

/* 听懂句子 - 橙色渐变 */
.vocab-item-listening {
  background: linear-gradient(180deg, #FFB395 0%, #FFFFFF 100%);
}

/* 跟读句子 - 粉色渐变 */
.vocab-item-speaking {
  background: linear-gradient(180deg, #FFACAF 0%, #FFFFFF 100%);
}

/* 实战对话 - 黄色渐变 */
.vocab-item-dialogue {
  background: linear-gradient(180deg, #FFE37D 0%, #FFFFFF 100%);
}

.vocab-item-label {
  font-size: 15px;
  font-weight: 400;
  color: #1B1B1B;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.vocab-item-value {
  font-size: 28px;
  font-weight: 600;
  color: #1B1B1B;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

/* ==================== 徽章卡片 ==================== */
.badge-card {
  margin-top: 20rpx;
  border-radius: 16px;
  padding: 20px;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.badge-header {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.badge-title {
  font-size: 20px;
  font-weight: 600;
  color: #1B1B1B;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.badge-subtitle {
  font-size: 14px;
  font-weight: 400;
  color: #999999;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.badge-soon {
  font-size: 14px;
  font-weight: 400;
  color: #999999;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

/* ==================== 复习卡片（原有样式保留） ==================== */
.review-card {
  margin-top: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.review-card.empty {
  opacity: 0.8;
}

.review-card-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.review-card-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
}

.review-card-count {
  font-size: 28rpx;
  color: #666666;
}

.due-deck-list {
  margin-bottom: 24rpx;
}

.due-deck-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.due-deck-item:last-child {
  border-bottom: none;
}

.due-deck-name {
  font-size: 30rpx;
  color: #333333;
}

.due-deck-cards {
  font-size: 26rpx;
  color: #999999;
}

.empty-text {
  display: block;
  text-align: center;
  font-size: 30rpx;
  color: #999999;
  padding: 40rpx 0;
}

.empty-sub {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #bbbbbb;
  margin-bottom: 24rpx;
}

/* 主要按钮 */
.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #191919;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.primary-btn[disabled] {
  background: #cccccc;
  color: #ffffff;
}

.primary-btn::after {
  border: none;
}

/* 次要按钮 */
.ghost-btn {
  width: auto;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 32rpx;
  background: transparent;
  color: #666666;
  font-size: 28rpx;
  border: 1rpx solid #dddddd;
  border-radius: 32rpx;
}

.ghost-btn::after {
  border: none;
}

/* 统计卡片 */
.stats-card {
  margin-top: 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stats-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #191919;
  line-height: 1.2;
}

.stats-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* ==================== 复习会话视图 ==================== */
.session {
  padding: 0 16rpx 40rpx;
  box-sizing: border-box;
}

.session-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.timer {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timer-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #191919;
}

.timer-sub {
  font-size: 22rpx;
  color: #999999;
  margin-top: 4rpx;
}

.progress {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-k {
  font-size: 22rpx;
  color: #999999;
}

.progress-v {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
  margin-top: 4rpx;
}

/* 答题卡片 */
.card {
  margin-top: 20rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-hd {
  margin-bottom: 32rpx;
  text-align: center;
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
}

.card-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 提示区域 */
.prompt {
  margin-bottom: 32rpx;
}

/* 中文提示 */
.prompt-zh {
  text-align: center;
  padding: 40rpx 0;
}

.prompt-zh-title {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.prompt-zh-main {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #111111;
  margin-bottom: 24rpx;
}

.audio-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.audio-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 32rpx;
  background: #f5f5f5;
  color: #666666;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: none;
}

.audio-btn[disabled] {
  opacity: 0.5;
}

.audio-btn::after {
  border: none;
}

.audio-btn.playing {
  background: #e8f4ff;
  color: #1890ff;
}

.audio-tip {
  font-size: 24rpx;
  color: #bbbbbb;
}

/* 音频播放区域 */
.prompt-audio {
  text-align: center;
  padding: 40rpx 0;
}

.prompt-audio-title {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

.audio-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 24rpx;
  background: #f5f5f5;
  border-radius: 50%;
}

.audio-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.6;
}

.audio-icon.playing {
  animation: pulse 1s infinite;
  opacity: 1;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.audio-text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.opt {
  padding: 28rpx 32rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.opt-text {
  display: block;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.opt-pinyin {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.opt-ok {
  background: #e6f7e6;
  border-color: #52c41a;
}

.opt-bad {
  background: #fff1f0;
  border-color: #ff4d4f;
}

.opt-disabled {
  opacity: 0.5;
}

/* 反馈 */
.feedback {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.feedback-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.feedback-icon {
  font-size: 40rpx;
  font-weight: 700;
}

.feedback-text {
  font-size: 32rpx;
  font-weight: 600;
}

/* 录音区域 */
.record-section {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.record-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  margin-bottom: 20rpx;
  text-align: center;
}

.record-controls {
  display: flex;
  justify-content: space-between;
  gap: 40rpx;
  margin-bottom: 16rpx;
  padding: 0 10rpx;
}

.record-btn-primary {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  background: #FF5722;
  border-radius: 50%;
  border: 4rpx solid #FF5722;
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3);
}

.record-btn-primary.recording {
  background: #ffffff;
  border-color: #FF5722;
  animation: pulse-record 1.5s infinite;
}

@keyframes pulse-record {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 12rpx 32rpx rgba(255, 87, 34, 0.5);
  }
}

.record-icon-primary {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 8rpx;
  filter: brightness(0) invert(1);
}

.record-btn-primary.recording .record-icon-primary {
  filter: none;
}

.record-btn-text-primary {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.record-btn-primary.recording .record-btn-text-primary {
  color: #FF5722;
}

/* 录音后状态的按钮 */
.record-btn-secondary {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  background: #ffffff;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.record-btn-secondary.play-btn {
  background: #FF5722;
  border-color: #FF5722;
  box-shadow: 0 8rpx 24rpx rgba(255, 87, 34, 0.3);
}

.record-btn-secondary.rerecord-btn {
  background: #FFF5F2;
  border-color: #FF5722;
}

.record-icon-secondary {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.record-btn-secondary.play-btn .record-icon-secondary {
  filter: brightness(0) invert(1);
}

.record-btn-secondary.rerecord-btn .record-icon-secondary {
  filter: invert(40%) sepia(80%) saturate(2000%) hue-rotate(350deg);
}

.record-btn-text-secondary {
  font-size: 22rpx;
  color: #666666;
}

.record-btn-secondary.play-btn .record-btn-text-secondary {
  color: #ffffff;
}

.record-btn-secondary.rerecord-btn .record-btn-text-secondary {
  color: #FF5722;
}

.next-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #191919;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
}

.next-btn::after {
  border: none;
}

/* ==================== 结果视图 ==================== */
.result {
  padding: 0 24rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.result-card {
  width: 100%;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.result-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 40rpx;
}

.result-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.result-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #191919;
}

.result-label {
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.result-divider {
  font-size: 48rpx;
  color: #dddddd;
  font-weight: 300;
}

.result-rate {
  margin-bottom: 32rpx;
}

.rate-value {
  display: block;
  font-size: 72rpx;
  font-weight: 700;
  color: #52c41a;
}

.rate-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
  margin-top: 8rpx;
}

.result-reward {
  margin-bottom: 40rpx;
}

.reward-text {
  font-size: 28rpx;
  color: #faad14;
  font-weight: 500;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-actions .primary-btn,
.result-actions .ghost-btn {
  width: 100%;
}
