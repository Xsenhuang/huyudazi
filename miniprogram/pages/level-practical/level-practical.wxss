.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F7F7F7;
}

.dialogue-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
  box-sizing: border-box;
}

.footer-actions {
  padding: 32rpx;
  background-color: #FDFBF7;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.03);
}

.primary-btn {
  width: 100%;
  background: var(--color-primary, #E8B05B);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  padding: 24rpx 0;
  line-height: 1.5;
  flex-shrink: 0;
}

.primary-btn::after {
  border: none;
}