<scroll-view class="page" scroll-y>
  <view class="custom-nav" style="{{customNavStyle}}">
    <image class="custom-nav-logo" style="{{customNavLogoStyle}}" src="../../assets/materials/logo-image.png" mode="aspectFill" />
  </view>

  <view class="content" style="{{contentStyle}}">
    <text class="page-title">学习记录</text>

    <view class="record-card">
      <view class="switcher-wrap">
        <view class="switcher-bg">
          <view class="switcher-item {{mode === 'day' ? 'active' : ''}}" data-mode="day" bindtap="handleModeChange">日</view>
          <view class="switcher-item {{mode === 'week' ? 'active' : ''}}" data-mode="week" bindtap="handleModeChange">周</view>
          <view class="switcher-item {{mode === 'month' ? 'active' : ''}}" data-mode="month" bindtap="handleModeChange">月</view>
        </view>
      </view>

      <view class="date-row">
        <button class="date-btn" hover-class="none" disabled="{{isPrevDisabled}}" bindtap="handlePrevPeriod">
          <image class="date-arrow" src="../../assets/icons/arrow-left.svg" mode="aspectFit" />
        </button>
        <text class="date-text">{{activeLabel}}</text>
        <button class="date-btn" hover-class="none" disabled="{{isNextDisabled}}" bindtap="handleNextPeriod">
          <image class="date-arrow" src="../../assets/icons/arrow-right.svg" mode="aspectFit" />
        </button>
      </view>

      <view class="stats-grid">
        <view class="stat-card">
          <text class="stat-label">已学词汇</text>
          <text class="stat-value">{{activeSummary ? activeSummary.vocab : 9}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">听懂句子</text>
          <text class="stat-value">{{activeSummary ? activeSummary.listening : 5}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">跟读句子</text>
          <text class="stat-value">{{activeSummary ? activeSummary.shadowing : 4}}</text>
        </view>
        <view class="stat-card">
          <text class="stat-label">实战对话</text>
          <text class="stat-value">{{activeSummary ? activeSummary.practical : 6}}</text>
        </view>
        <view class="stat-card stat-card-wide">
          <text class="stat-label">已学场景</text>
          <text class="stat-value">{{activeSummary ? activeSummary.scenes : 1}}</text>
        </view>
      </view>
    </view>

    <view class="settings-card">
      <view class="setting-item" bindtap="handleAddToMiniprogram">
        <view class="setting-left">
          <image class="setting-icon" src="../../assets/icons/add-to.svg" mode="aspectFit" />
          <text class="setting-text">添加到我的小程序</text>
        </view>
        <image class="setting-arrow" src="../../assets/icons/arrow-right.svg" mode="aspectFit" />
      </view>
      <view class="setting-divider"></view>
      <view class="setting-item" bindtap="handleAddToDesktop">
        <view class="setting-left">
          <image class="setting-icon" src="../../assets/icons/phone.svg" mode="aspectFit" />
          <text class="setting-text">添加到手机桌面</text>
        </view>
        <image class="setting-arrow" src="../../assets/icons/arrow-right.svg" mode="aspectFit" />
      </view>
      <view class="setting-divider"></view>
      <view class="setting-item" bindtap="handleContactDeveloper">
        <view class="setting-left">
          <image class="setting-icon" src="../../assets/icons/call.svg" mode="aspectFit" />
          <text class="setting-text">联系开发者</text>
        </view>
        <image class="setting-arrow" src="../../assets/icons/arrow-right.svg" mode="aspectFit" />
      </view>
    </view>

    <view class="bottom-spacer"></view>
  </view>
</scroll-view>
