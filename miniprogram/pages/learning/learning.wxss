.container {
  width: 100vw;
  min-height: 100vh;
  background-color: #F8F8F8;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* --- 词汇学习阶段 --- */
.vocab-learning {
  display: flex;
  flex-direction: column;
  padding: calc(20rpx + env(safe-area-inset-top)) 40rpx 20rpx;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
}

/* 进度条 */
.progress-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-track {
  flex: 1;
  height: 8px;
  background-color: #E5E5E5;
  border-radius: 4px;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background-color: #F15D22;
  border-radius: 4px;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 28rpx;
  color: #26292C;
  font-weight: 400;
  font-family: PingFang SC;
}

/* 标题区域 */
.learning-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 24px;
}

.learning-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #26292C;
  margin-bottom: 8rpx;
  font-family: PingFang SC;
}

/* 卡片堆叠容器 */
.cards-stack {
  flex-grow: 0;
  flex-shrink: 0;
  flex-basis: 500px;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 24px;
  height: 500px;
}

/* 侧边背景卡片 */
.card-side {
  position: absolute;
  width: 600rpx;
  height: 500px;
  background-color: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.card-left {
  transform: translateX(-60rpx) scale(0.92);
  opacity: 0.7;
}

.card-right {
  transform: translateX(60rpx) scale(0.92);
  opacity: 0.7;
}

.card-side-word {
  font-size: 48rpx;
  font-weight: 600;
  color: #CCC;
  font-family: PingFang SC;
}

/* 主卡片 */
.card-main {
  position: relative;
  width: 600rpx;
  height: 500px;
  background-color: #FFFFFF;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  z-index: 10;
  transition: transform 0.1s ease;
}

.card-main-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

/* 卡片头部 */
.card-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.card-word-main {
  font-size: 80rpx;
  font-weight: bold;
  color: #26292C;
  font-family: PingFang SC;
}

.card-pinyin-main {
  font-size: 32rpx;
  color: #666;
  font-family: PingFang SC;
}

.card-mandarin-main {
  font-size: 32rpx;
  color: #666;
  font-family: PingFang SC;
}

.tag-container {
  margin-top: 8rpx;
  padding: 8rpx 32rpx;
  background-color: #F5F5F5;
  border-radius: 32rpx;
}

.tag-text {
  font-size: 26rpx;
  color: #666;
  font-family: PingFang SC;
}

/* 播放按钮 */
.audio-circle {
  width: 120rpx;
  height: 120rpx;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.audio-circle:active {
  transform: scale(0.95);
}

.audio-circle.playing {
  background-color: #F15D22;
  animation: pulse 1s infinite;
}

.audio-icon-large {
  width: 48rpx;
  height: 48rpx;
}

@keyframes pulse {
  0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(241, 93, 34, 0.4); }
  50% { transform: scale(1.05); box-shadow: 0 0 0 20rpx rgba(241, 93, 34, 0); }
  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(241, 93, 34, 0); }
}

/* 例句 */
.example-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 48px;
  padding: 0 20rpx;
}

.example-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.example-item {
  width: 100%;
  display: flex;
  justify-content: center;
}

.example-label {
  font-size: 28rpx;
  color: #999;
  font-family: PingFang SC;
}

.example-text {
  font-size: 28rpx;
  color: #F15D22;
  text-align: center;
  font-family: PingFang SC;
  line-height: 1.6;
}

/* 录音按钮组 */
.record-buttons {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 0;
}

.record-btn-primary-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn-primary-label {
  margin-top: 12px;
  font-size: 24rpx;
  color: #1B1B1B;
  font-weight: 500;
  font-family: PingFang SC;
}

/* 默认状态：按住跟读大按钮 */
.record-btn-primary {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  background: #F15D22;
  border-radius: 24px;
  border: 4rpx solid #F15D22;
  box-shadow: 0 4px 0 0 #954221;
}

.record-btn-primary.recording {
  background: #ffffff;
  border-color: #F15D22;
  animation: pulse-record 1.5s infinite;
}

@keyframes pulse-record {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4px 0 0 #954221;
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 4px 0 0 #954221;
  }
}

.record-icon-primary {
  width: 36px;
  height: 36px;
  margin-bottom: 0;
  filter: brightness(0) invert(1);
}

.record-btn-primary.recording .record-icon-primary {
  filter: none;
}

/* 录音后状态：播放跟读 + 重新跟读 */
.record-btn-secondary {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.record-btn-icon-wrap-secondary {
  width: 160rpx;
  height: 160rpx;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-btn-icon-wrap-secondary.primary {
  background: linear-gradient(135deg, #F15D22 0%, #E85A20 100%);
  box-shadow: 0 8rpx 24rpx rgba(241, 93, 34, 0.3);
}

.record-btn-icon-wrap-secondary.secondary {
  background-color: #FFF0EB;
  border: 2rpx solid #F15D22;
}

.record-btn-icon-secondary {
  width: 36px;
  height: 36px;
}

.record-btn-icon-wrap-secondary.primary .record-btn-icon-secondary {
  filter: brightness(0) invert(1);
}

.record-btn-icon-wrap-secondary.secondary .record-btn-icon-secondary {
  filter: invert(40%) sepia(80%) saturate(2000%) hue-rotate(350deg);
}

/* 底部导航按钮 */
.nav-buttons {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 80rpx;
  margin-bottom: -4rpx;
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 30rpx;
  color: #26292C;
  font-family: PingFang SC;
  transition: all 0.2s ease;
}

.nav-btn.disabled {
  opacity: 0.3;
}

.nav-btn.primary {
  color: #F15D22;
  font-weight: 500;
}

.nav-icon {
  width: 24px;
  height: 24px;
}

/* 滑动提示 */
.learning-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  font-family: PingFang SC;
  margin-bottom: 12rpx;
}

/* 完成提示 */
.complete-tip {
  text-align: center;
  padding: 16rpx 0;
}

.complete-tip text {
  font-size: 24rpx;
  color: #999;
  font-family: PingFang SC;
}

/* --- 复习阶段 --- */
.review-area {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-sizing: border-box;
  align-items: center;
}

.review-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.review-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.review-progress {
  font-size: 32rpx;
  color: #999;
  font-weight: bold;
}

.review-audio-box {
  width: 240rpx;
  height: 240rpx;
  background-color: #FFF;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(241, 93, 34, 0.2);
  border: 4rpx solid #F15D22;
  margin: auto 0;
  flex-shrink: 0;
}

.review-audio-box:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.review-audio-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.review-audio-icon.playing {
  animation: pulse 1s infinite;
}

.review-audio-text {
  font-size: 28rpx;
  color: #F15D22;
  font-weight: 500;
}

.review-options {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
  flex-shrink: 0;
  margin-bottom: 40rpx;
}

.review-option {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFF;
  padding: 32rpx 16rpx;
  border-radius: 24rpx;
  font-size: 32rpx;
  color: #333;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.review-option:active {
  background-color: #FFF5F0;
  border-color: #F15D22;
  color: #F15D22;
}

/* 滑动动画 */
.slide-out-left {
  animation: slideOutLeft 0.3s ease forwards;
}

.slide-out-right {
  animation: slideOutRight 0.3s ease forwards;
}

@keyframes slideOutLeft {
  to {
    transform: translateX(-100%) rotate(-20deg);
    opacity: 0;
  }
}

@keyframes slideOutRight {
  to {
    transform: translateX(100%) rotate(20deg);
    opacity: 0;
  }
}
