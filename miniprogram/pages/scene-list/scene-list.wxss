page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FDFBF7;
}

.page-scroll {
  flex: 1;
  height: 100%;
}

.header {
  display: flex;
  padding: 40rpx;
  background-color: #ffffff;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.02);
}

.header-icon {
  width: 120rpx;
  height: 120rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 24rpx;
  color: #666;
}

.scene-list {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.scene-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  align-items: center;
  transition: transform 0.2s;
}

.scene-card:active {
  transform: scale(0.98);
}

.scene-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.scene-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.scene-target {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.mastery-tag {
  align-self: flex-start;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.mastery-tag.L0 {
  background-color: #F0F0F0;
  color: #999;
}

.mastery-tag.L1 {
  background-color: #E6F7FF;
  color: #1890FF;
}

.mastery-tag.L2 {
  background-color: #F6FFED;
  color: #13C2C2;
}

.mastery-tag.L3 {
  background-color: #F6FFED;
  color: #52C41A;
}

.scene-arrow {
  width: 40rpx;
  height: 40rpx;
  margin-left: 20rpx;
  opacity: 0.3;
}
